{
  "name": "@useplume/react",
  "version": "0.2.4",
  "description": "React adapter for Plume — a customizable rich text editor built on tiptap.",
  "license": "MIT",
  "type": "module",
  "author": "Ömer Faruk Gezer",
  "keywords": [
    "editor",
    "rich-text",
    "wysiwyg",
    "tiptap",
    "react",
    "plume"
  ],
  "homepage": "https://github.com/omerfarukgzr/plume#readme",
  "bugs": "https://github.com/omerfarukgzr/plume/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omerfarukgzr/plume.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@tiptap/react": "^3.23.6"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@useplume/core": "workspace:^",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tiptap/core": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@useplume/core": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
