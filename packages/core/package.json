{
  "name": "@useplume/core",
  "version": "0.2.1",
  "description": "Framework-agnostic core for Plume — a customizable rich text editor built on tiptap.",
  "license": "MIT",
  "type": "module",
  "author": "Ömer Faruk Gezer",
  "keywords": [
    "editor",
    "rich-text",
    "wysiwyg",
    "tiptap",
    "prosemirror",
    "plume"
  ],
  "homepage": "https://github.com/omerfarukgzr/plume#readme",
  "bugs": "https://github.com/omerfarukgzr/plume/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omerfarukgzr/plume.git",
    "directory": "packages/core"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@tiptap/extension-document": "^3.23.6",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-list-item": "^3.23.6",
    "@tiptap/extension-ordered-list": "^3.23.6",
    "@tiptap/extension-subscript": "^3.23.6",
    "@tiptap/extension-superscript": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-text-style": "^3.23.6",
    "@tiptap/extensions": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "tiptap-footnotes": "^3.0.1"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
    "@tiptap/pm": "^3.0.0"
  },
  "devDependencies": {
    "@tiptap/core": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
