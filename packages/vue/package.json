{
  "name": "@useplume/vue",
  "version": "0.2.2",
  "description": "Vue 3 adapter for Plume — a customizable rich text editor built on tiptap.",
  "license": "MIT",
  "type": "module",
  "author": "Ömer Faruk Gezer",
  "keywords": [
    "editor",
    "rich-text",
    "wysiwyg",
    "tiptap",
    "vue",
    "plume"
  ],
  "homepage": "https://github.com/omerfarukgzr/plume#readme",
  "bugs": "https://github.com/omerfarukgzr/plume/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omerfarukgzr/plume.git",
    "directory": "packages/vue"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@tiptap/vue-3": "^3.23.6"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@useplume/core": "workspace:^",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@tiptap/core": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@useplume/core": "workspace:*",
    "@testing-library/vue": "^8.1.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vue": "^3.5.34"
  },
  "publishConfig": {
    "access": "public"
  }
}
